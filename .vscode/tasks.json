{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build-buildsys",
            "command": "haxe",
            "type": "process",
            "args": [
                "${cwd}/buildsys.hxml"
            ],
            "problemMatcher": ["$haxe"],
            "presentation": {
                "echo": true,
                "reveal": "silent",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            }
        },
        {
            "label": "build",
            "dependsOn": [
                "build-buildsys"
            ],
            "command": "node",
            "type": "process",
            "args": [
                "${cwd}/build.js"
            ],
            "problemMatcher": ["$msCompile", "$haxe-absolute"],
            "presentation": {
                "echo": true,
                "reveal": "silent",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            }
        }
    ]
}